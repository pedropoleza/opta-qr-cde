# Spark Check-in — variáveis de ambiente (seção "Estado atual do código")
# Em produção (Vercel), o 👤 Time adiciona estes valores em Project Settings →
# Environment Variables.

# --- Banco (Postgres / Supabase "Sparkleads OS", ref nsqwgjbgcdqyzozyaltz) ---
# Vercel é serverless: use o POOLER (porta 6543, pgbouncer) na DATABASE_URL e a
# conexão DIRETA (porta 5432) na DIRECT_URL (usada só por migrations).
# Troque [PASSWORD] pela senha do banco (Supabase → Project Settings → Database).
DATABASE_URL="postgresql://postgres.nsqwgjbgcdqyzozyaltz:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.nsqwgjbgcdqyzozyaltz:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Em desenvolvimento local, ambos apontam para o Postgres local:
# DATABASE_URL="postgresql://postgres@localhost:5432/spark_checkin"
# DIRECT_URL="postgresql://postgres@localhost:5432/spark_checkin"

# --- Segredos (32 bytes aleatórios cada — gerar com: openssl rand -hex 32) ---
JWT_SIGNING_KEY=""
TICKET_TOKEN_SECRET=""

# --- Domínio público do app (vai impresso na URL dentro do QR Code) ---
# Em produção, a URL do projeto na Vercel (ex.: https://spark-checkin.vercel.app)
APP_BASE_URL="http://localhost:3000"

# --- Etapa 3 — envio de e-mail (D1 = híbrida C: app envia + grava status no GHL) ---
# Provedor próprio (Resend recomendado). Sem chave, o disponível roda em modo
# "dry-run" (grava EmailLog mas não dispara) para permitir testes.
EMAIL_PROVIDER="resend"          # resend | none
EMAIL_PROVIDER_KEY=""            # Resend API key (re_...)
EMAIL_FROM="Spark Check-in <checkin@seudominio.com>"

# --- Etapa 4 — integração HighLevel (pendente de app no GHL Developer Portal) ---
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI=""

# --- WhatsApp não-oficial (Stevo / wuzapi) — envio do PDF por URL ---
STEVO_API_URL=""                 # ex.: https://smv2-7.stevo.chat
STEVO_API_KEY=""                 # apikey da instância

# --- WhatsApp OFICIAL (Meta Cloud API) — PDF como documento anexado ---
# Proativo (fora das 24h) exige um template UTILITY aprovado com header DOCUMENT.
# O PDF de cada convidado entra no header pela URL /api/ticket/{token}/pdf.
WHATSAPP_PHONE_NUMBER_ID=""       # ID do número (Graph API)
WHATSAPP_TOKEN=""                 # token permanente (system user)
WHATSAPP_TEMPLATE_NAME=""         # nome do template aprovado (header DOCUMENT)
WHATSAPP_TEMPLATE_LANG="pt_BR"    # idioma do template
WHATSAPP_API_VERSION="v21.0"      # versão do Graph API

# Seed inicial (npx prisma db seed)
SEED_ADMIN_EMAIL="info@sparkleads.pro"
SEED_ADMIN_PASSWORD=""
